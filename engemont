<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Engemont — Qualificação de Leads</title>
<style>
  :root{
    --azul:#0b3d6e; --azul-claro:#1565c0; --verde:#1e8e3e; --vermelho:#c5221f;
    --cinza-bg:#f4f6f8; --cinza-borda:#dde2e7; --texto:#2c3440; --texto-claro:#6b7785;
  }
  *{box-sizing:border-box;}
  body{
    margin:0; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
    background:var(--cinza-bg); color:var(--texto);
  }
  header{
    background:var(--azul); color:#fff; padding:18px 28px; display:flex;
    align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px;
  }
  header h1{font-size:18px; margin:0; font-weight:600;}
  header .sub{font-size:12.5px; opacity:.85;}
  .container{max-width:1200px; margin:0 auto; padding:20px;}
  .toolbar{
    display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-bottom:16px;
    background:#fff; padding:14px 16px; border-radius:10px; border:1px solid var(--cinza-borda);
  }
  .toolbar input[type=text]{
    flex:1; min-width:180px; padding:9px 12px; border:1px solid var(--cinza-borda);
    border-radius:6px; font-size:14px;
  }
  .toolbar select{
    padding:9px 10px; border:1px solid var(--cinza-borda); border-radius:6px; font-size:14px; background:#fff;
  }
  .toolbar button{
    padding:9px 14px; border:1px solid var(--azul-claro); background:#fff; color:var(--azul-claro);
    border-radius:6px; font-size:13.5px; cursor:pointer; font-weight:600;
  }
  .toolbar button:hover{background:#eaf1fb;}
  .stats{display:flex; gap:10px; margin-bottom:16px; flex-wrap:wrap;}
  .stat-card{
    flex:1; min-width:130px; background:#fff; border:1px solid var(--cinza-borda); border-radius:10px;
    padding:12px 16px;
  }
  .stat-card .num{font-size:22px; font-weight:700; color:var(--azul);}
  .stat-card .label{font-size:12px; color:var(--texto-claro); margin-top:2px;}
  table{width:100%; border-collapse:collapse; background:#fff; border-radius:10px; overflow:hidden; border:1px solid var(--cinza-borda);}
  thead th{
    text-align:left; font-size:12px; text-transform:uppercase; letter-spacing:.03em;
    color:var(--texto-claro); padding:10px 12px; border-bottom:1px solid var(--cinza-borda); background:#fafbfc;
  }
  tbody td{padding:11px 12px; border-bottom:1px solid #eef1f4; font-size:13.5px; vertical-align:top;}
  tbody tr:last-child td{border-bottom:none;}
  tbody tr:hover{background:#fafcff;}
  .nome{font-weight:600;}
  .meta{color:var(--texto-claro); font-size:12px; margin-top:2px;}
  .badge{
    display:inline-block; padding:3px 9px; border-radius:20px; font-size:11.5px; font-weight:600;
  }
  .badge-pendente{background:#fff3cd; color:#8a6500;}
  .badge-qualificado{background:#e3f6e8; color:var(--verde);}
  .badge-nao-qualificado{background:#fbe6e5; color:var(--vermelho);}
  .acoes{display:flex; gap:6px; flex-wrap:wrap;}
  .btn{
    border:none; border-radius:6px; padding:7px 11px; font-size:12.5px; cursor:pointer; font-weight:600;
  }
  .btn-sim{background:var(--verde); color:#fff;}
  .btn-nao{background:var(--vermelho); color:#fff;}
  .btn-editar{background:#eef1f4; color:var(--texto);}
  .loading, .empty{text-align:center; padding:40px; color:var(--texto-claro);}
  /* modal */
  .overlay{
    position:fixed; inset:0; background:rgba(20,30,45,.45); display:none;
    align-items:center; justify-content:center; z-index:50; padding:16px;
  }
  .overlay.show{display:flex;}
  .modal{
    background:#fff; border-radius:12px; padding:24px; width:100%; max-width:440px;
    box-shadow:0 12px 40px rgba(0,0,0,.2);
  }
  .modal h3{margin:0 0 4px; font-size:16px;}
  .modal .modal-sub{font-size:13px; color:var(--texto-claro); margin-bottom:16px;}
  .modal label{display:block; font-size:12.5px; font-weight:600; margin:12px 0 5px;}
  .modal select, .modal textarea, .modal input{
    width:100%; padding:8px 10px; border:1px solid var(--cinza-borda); border-radius:6px; font-size:13.5px; font-family:inherit;
  }
  .modal textarea{resize:vertical; min-height:60px;}
  .modal-actions{display:flex; gap:8px; justify-content:flex-end; margin-top:20px;}
  .modal-actions button{padding:9px 16px; border-radius:6px; font-size:13.5px; font-weight:600; cursor:pointer; border:none;}
  .btn-cancelar{background:#eef1f4; color:var(--texto);}
  .btn-salvar{background:var(--azul-claro); color:#fff;}
  .toast{
    position:fixed; bottom:20px; right:20px; background:var(--texto); color:#fff; padding:12px 18px;
    border-radius:8px; font-size:13.5px; opacity:0; transform:translateY(10px); transition:.25s; z-index:60;
  }
  .toast.show{opacity:1; transform:translateY(0);}
  @media (max-width: 720px){
    table, thead, tbody, tr, th, td{display:block;}
    thead{display:none;}
    tbody tr{border-bottom:1px solid var(--cinza-borda); padding:10px 0;}
    tbody td{border-bottom:none; padding:4px 12px;}
  }
</style>
</head>
<body>

<header>
  <div>
    <h1>Engemont — Qualificação de Leads</h1>
    <div class="sub">Marque cada lead recebido como qualificado ou não qualificado</div>
  </div>
</header>

<div class="container">

  <div class="stats" id="stats"></div>

  <div class="toolbar">
    <input type="text" id="busca" placeholder="Buscar por nome, e-mail ou empresa...">
    <select id="filtroStatus">
      <option value="">Todos os status</option>
      <option value="Pendente">Pendente</option>
      <option value="Qualificado">Qualificado</option>
      <option value="Não Qualificado">Não Qualificado</option>
    </select>
    <button id="btnAtualizar">↻ Atualizar</button>
  </div>

  <div id="conteudo" class="loading">Carregando leads...</div>
</div>

<div class="overlay" id="overlay">
  <div class="modal">
    <h3 id="modalTitulo">Qualificar lead</h3>
    <div class="modal-sub" id="modalSub"></div>

    <label>Quem está marcando?</label>
    <input type="text" id="campoUsuario" placeholder="Seu nome">

    <label id="labelMotivo">Motivo</label>
    <select id="campoMotivo"></select>

    <label>Observações (opcional)</label>
    <textarea id="campoObs" placeholder="Ex.: já tem orçamento em andamento, ligar semana que vem..."></textarea>

    <div class="modal-actions">
      <button class="btn-cancelar" id="btnCancelar">Cancelar</button>
      <button class="btn-salvar" id="btnSalvar">Salvar</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ============================================================
// CONFIGURAÇÃO — cole aqui a URL do seu Apps Script Web App
// ============================================================
const SCRIPT_URL = "https://script.google.com/a/macros/laisvalentini.com/s/AKfycbzQuEdtNTnzkhkaIyZTDI9GZ_JGEWId-H14pMBotz7jnV4tCdwOi5XDmtnA7rz6RduWBA/exec";
// ============================================================

const MOTIVOS_QUALIFICADO = [
  "Orçamento de projeto", "Cliente em potencial", "Indicação", "Outro (qualificado)"
];
const MOTIVOS_NAO_QUALIFICADO = [
  "Currículo / candidato a vaga", "Fornecedor tentando vender", "Contato errado / duplicado", "Sem interesse real", "Outro (não qualificado)"
];

let leads = [];
let pendingAction = null; // { id, status }

const el = (id) => document.getElementById(id);

function toast(msg){
  const t = el('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2600);
}

async function carregarLeads(){
  el('conteudo').innerHTML = '<div class="loading">Carregando leads...</div>';
  try{
    const res = await fetch(SCRIPT_URL);
    const data = await res.json();
    if(!data.ok) throw new Error(data.error || 'Erro desconhecido');
    leads = data.leads;
    renderizar();
  }catch(err){
    el('conteudo').innerHTML = '<div class="empty">Não foi possível carregar os leads.<br>'+
      'Verifique se a URL do Apps Script foi configurada corretamente.<br><small>'+err.message+'</small></div>';
  }
}

function statusBadge(status){
  if(status === 'Qualificado') return '<span class="badge badge-qualificado">Qualificado</span>';
  if(status === 'Não Qualificado') return '<span class="badge badge-nao-qualificado">Não Qualificado</span>';
  return '<span class="badge badge-pendente">Pendente</span>';
}

function renderStats(){
  const total = leads.length;
  const pendentes = leads.filter(l => !l.Status_Qualificacao || l.Status_Qualificacao === 'Pendente').length;
  const qualificados = leads.filter(l => l.Status_Qualificacao === 'Qualificado').length;
  const naoQualificados = leads.filter(l => l.Status_Qualificacao === 'Não Qualificado').length;
  const taxa = total ? Math.round((qualificados/(qualificados+naoQualificados || 1))*100) : 0;

  el('stats').innerHTML = `
    <div class="stat-card"><div class="num">${total}</div><div class="label">Total de leads</div></div>
    <div class="stat-card"><div class="num">${pendentes}</div><div class="label">Pendentes</div></div>
    <div class="stat-card"><div class="num">${qualificados}</div><div class="label">Qualificados</div></div>
    <div class="stat-card"><div class="num">${naoQualificados}</div><div class="label">Não qualificados</div></div>
    <div class="stat-card"><div class="num">${taxa}%</div><div class="label">Taxa de qualificação (dos avaliados)</div></div>
  `;
}

function renderizar(){
  renderStats();
  const busca = el('busca').value.trim().toLowerCase();
  const filtroStatus = el('filtroStatus').value;

  let filtrados = leads.filter(l => {
    const status = l.Status_Qualificacao || 'Pendente';
    if(filtroStatus && status !== filtroStatus) return false;
    if(busca){
      const alvo = [l.Nome, l.Email, l.Empresa].join(' ').toLowerCase();
      if(!alvo.includes(busca)) return false;
    }
    return true;
  });

  // pendentes primeiro, depois por data mais recente
  filtrados.sort((a,b) => {
    const pa = (a.Status_Qualificacao || 'Pendente') === 'Pendente' ? 0 : 1;
    const pb = (b.Status_Qualificacao || 'Pendente') === 'Pendente' ? 0 : 1;
    if(pa !== pb) return pa - pb;
    return String(b.Data_Conversao).localeCompare(String(a.Data_Conversao));
  });

  if(filtrados.length === 0){
    el('conteudo').innerHTML = '<div class="empty">Nenhum lead encontrado com esse filtro.</div>';
    return;
  }

  const linhas = filtrados.map(l => {
    const status = l.Status_Qualificacao || 'Pendente';
    return `
      <tr>
        <td>
          <div class="nome">${escapeHtml(l.Nome || '(sem nome)')}</div>
          <div class="meta">${escapeHtml(l.Email || '')}</div>
        </td>
        <td>${escapeHtml(l.Empresa || '—')}</td>
        <td>${escapeHtml(l.Telefone || '—')}</td>
        <td><div class="meta">${escapeHtml(String(l.Data_Conversao || '').slice(0,10))}</div></td>
        <td>${statusBadge(status)}${l.Motivo ? '<div class="meta">'+escapeHtml(l.Motivo)+'</div>' : ''}</td>
        <td>
          <div class="acoes">
            <button class="btn btn-sim" onclick="abrirModal(${l.ID}, 'Qualificado')">✓ Qualificado</button>
            <button class="btn btn-nao" onclick="abrirModal(${l.ID}, 'Não Qualificado')">✕ Não qualificado</button>
          </div>
        </td>
      </tr>
    `;
  }).join('');

  el('conteudo').innerHTML = `
    <table>
      <thead>
        <tr>
          <th>Lead</th><th>Empresa</th><th>Telefone</th><th>Data</th><th>Status</th><th>Ação</th>
        </tr>
      </thead>
      <tbody>${linhas}</tbody>
    </table>
  `;
}

function escapeHtml(str){
  return String(str).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

function abrirModal(id, status){
  pendingAction = { id, status };
  const lead = leads.find(l => String(l.ID) === String(id));
  el('modalTitulo').textContent = status === 'Qualificado' ? 'Marcar como Qualificado' : 'Marcar como Não Qualificado';
  el('modalSub').textContent = lead ? `${lead.Nome || ''} — ${lead.Email || ''}` : '';

  const motivos = status === 'Qualificado' ? MOTIVOS_QUALIFICADO : MOTIVOS_NAO_QUALIFICADO;
  el('campoMotivo').innerHTML = motivos.map(m => `<option value="${escapeHtml(m)}">${escapeHtml(m)}</option>`).join('');
  el('campoObs').value = '';

  const usuarioSalvo = localStorage.getItem('engemont_crm_usuario') || '';
  el('campoUsuario').value = usuarioSalvo;

  el('overlay').classList.add('show');
}

function fecharModal(){
  el('overlay').classList.remove('show');
  pendingAction = null;
}

async function salvarQualificacao(){
  if(!pendingAction) return;
  const usuario = el('campoUsuario').value.trim();
  const motivo = el('campoMotivo').value;
  const obs = el('campoObs').value.trim();

  if(!usuario){
    toast('Informe seu nome antes de salvar.');
    return;
  }
  localStorage.setItem('engemont_crm_usuario', usuario);

  el('btnSalvar').disabled = true;
  el('btnSalvar').textContent = 'Salvando...';

  try{
    const res = await fetch(SCRIPT_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify({
        action: 'update',
        id: pendingAction.id,
        status: pendingAction.status,
        motivo: motivo,
        observacoes: obs,
        usuario: usuario
      })
    });
    const data = await res.json();
    if(!data.ok) throw new Error(data.error || 'Erro ao salvar');

    const lead = leads.find(l => String(l.ID) === String(pendingAction.id));
    if(lead){
      lead.Status_Qualificacao = pendingAction.status;
      lead.Motivo = motivo;
      lead.Observacoes = obs;
    }
    toast('Lead atualizado!');
    fecharModal();
    renderizar();
  }catch(err){
    toast('Erro ao salvar: ' + err.message);
  }finally{
    el('btnSalvar').disabled = false;
    el('btnSalvar').textContent = 'Salvar';
  }
}

el('btnAtualizar').addEventListener('click', carregarLeads);
el('busca').addEventListener('input', renderizar);
el('filtroStatus').addEventListener('change', renderizar);
el('btnCancelar').addEventListener('click', fecharModal);
el('btnSalvar').addEventListener('click', salvarQualificacao);
el('overlay').addEventListener('click', (e) => { if(e.target.id === 'overlay') fecharModal(); });

carregarLeads();
</script>
</body>
</html>
